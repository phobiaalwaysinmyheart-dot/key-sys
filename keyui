-- § 8 · TOAST SYSTEM
-- ════════════════════════════════════════════════════════════════

local _toastHolder

local TCOL = { Success=T.Green, Error=T.Red, Warning=T.Amber, Info=T.Blue }

local function Toast(msg, kind, dur)
    if not _toastHolder then return end
    kind = kind or "Info"
    dur  = dur  or 3
    local col  = TCOL[kind] or T.Acc

    local wrap = Frm(_toastHolder, T.Bg2, UDim2.new(1,0,0,38), nil, nil, 8)
    mkStroke(wrap, col, 1, 0.45)
    mkPad(wrap, 10, 10, 0, 0)
    wrap.ZIndex = 30

    local bar = Frm(wrap, col, UDim2.new(0,3,1,0), nil, nil, 3)
    bar.ZIndex = 31

    local lbl = Lbl(wrap, msg, T.Txt, 11, Enum.Font.Gotham)
    lbl.Position = UDim2.new(0,12,0,0)
    lbl.Size     = UDim2.new(1,-14,1,0)
    lbl.ZIndex   = 31

    wrap.Position = UDim2.new(1.1, 0, 0, 0)
    tw(wrap,
        TweenInfo.new(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Position = UDim2.new(0,0,0,0)})

    task.delay(dur, function()
        if wrap and wrap.Parent then
            tw(wrap, TI_Med, {Position=UDim2.new(1.1,0,0,0), BackgroundTransparency=1})
            task.delay(0.3, function() pcall(function() wrap:Destroy() end) end)
        end
    end)
end

