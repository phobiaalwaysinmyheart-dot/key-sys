end

-- TextBox constructor
function UI.TextBox(parent, props)
    local t = Instance.new("TextBox")
    t.BackgroundColor3 = props.Color or C.Panel
    t.BackgroundTransparency = props.BgTransparency or 0
    t.Size      = props.Size     or UDim2.new(1,0,0,40)
    t.Position  = props.Position or UDim2.new(0,0,0,0)
    t.AnchorPoint = props.Anchor or Vector2.new(0,0)
    t.Text      = props.Text     or ""
    t.PlaceholderText = props.Placeholder or ""
    t.TextColor3 = props.TextColor or C.Text
    t.PlaceholderColor3 = props.PlaceholderColor or C.TextFaint
    t.TextSize  = props.TextSize  or 13
    t.Font      = props.Font      or Enum.Font.Gotham
    t.ClearTextOnFocus = props.ClearOnFocus ~= nil and props.ClearOnFocus or false
    t.TextXAlignment = props.AlignX or Enum.TextXAlignment.Left
    t.BorderSizePixel = 0
    t.ClipsDescendants = true
    t.Name = props.Name or "TextBox"
    t.Parent = parent
    Corner(t, props.Corner or 8)
    Padding(t, nil, 0, 0, 12, 12)
    Stroke(t, C.PanelBorder, 1)
    -- Focus glow
    t.Focused:Connect(function()
        Tween(t, QuickInfo, {BackgroundColor3 = C.AccentSoft})
    end)
    t.FocusLost:Connect(function()
        Tween(t, QuickInfo, {BackgroundColor3 = props.Color or C.Panel})
    end)
    return t
end

-- Button constructor
function UI.Button(parent, props)
    local btn = Instance.new("TextButton")
    btn.BackgroundColor3 = props.Color or C.Accent
    btn.Size      = props.Size     or UDim2.new(1,0,0,40)
    btn.Position  = props.Position or UDim2.new(0,0,0,0)
    btn.AnchorPoint = props.Anchor or Vector2.new(0,0)
    btn.Text      = props.Text     or "Button"
    btn.TextColor3 = props.TextColor or Color3.new(1,1,1)
    btn.TextSize  = props.TextSize  or 13
    btn.Font      = props.Font      or Enum.Font.GothamBold
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.Name = props.Name or "Button"
    btn.Parent = parent
    Corner(btn, props.Corner or 8)

    -- Hover / press animations
    local base = props.Color or C.Accent
    btn.MouseEnter:Connect(function()
        Tween(btn, QuickInfo, {BackgroundColor3 = props.HoverColor or C.AccentGlow})
    end)
    btn.MouseLeave:Connect(function()
        Tween(btn, QuickInfo, {BackgroundColor3 = base})
    end)
    btn.MouseButton1Down:Connect(function()
        Tween(btn, QuickInfo, {BackgroundColor3 = props.PressColor or C.AccentSoft})
    end)
    btn.MouseButton1Up:Connect(function()
        Tween(btn, QuickInfo, {BackgroundColor3 = props.HoverColor or C.AccentGlow})
    end)

    if props.Callback then
        btn.MouseButton1Click:Connect(props.Callback)
    end
    return btn
end

