-- § 6 · UI CONSTRUCTOR HELPERS
-- ════════════════════════════════════════════════════════════════

local function mkCorner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 10)
    c.Parent = p
    return c
end

local function mkStroke(p, col, thick, trans)
    local s = Instance.new("UIStroke")
    s.Color = col or T.Bdr
    s.Thickness = thick or 1
    s.Transparency = trans or 0
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = p
    return s
end

local function mkPad(p, l, r, top, bot)
    local pd = Instance.new("UIPadding")
    pd.PaddingLeft   = UDim.new(0, l   or 0)
    pd.PaddingRight  = UDim.new(0, r   or 0)
    pd.PaddingTop    = UDim.new(0, top or 0)
    pd.PaddingBottom = UDim.new(0, bot or 0)
    pd.Parent = p
    return pd
end

local function mkGrad(p, cs, rot)
    local g = Instance.new("UIGradient")
    g.Color    = cs
    g.Rotation = rot or 0
    g.Parent   = p
    return g
end

local function mkListLayout(p, dir, ha, va, pad)
    local l = Instance.new("UIListLayout")
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.FillDirection = dir or Enum.FillDirection.Vertical
    l.HorizontalAlignment = ha or Enum.HorizontalAlignment.Left
    l.VerticalAlignment   = va or Enum.VerticalAlignment.Top
    l.Padding = UDim.new(0, pad or 0)
    l.Parent  = p
    return l
end

-- Frm: general-purpose frame
local function Frm(par, col, sz, pos, anch, r, alpha)
    local f = Instance.new("Frame")
    f.BackgroundColor3       = col   or T.Bg1
    f.BackgroundTransparency = alpha or 0
    f.Size       = sz   or UDim2.new(1,0,1,0)
    f.Position   = pos  or UDim2.new(0,0,0,0)
    f.AnchorPoint = anch or Vector2.new(0,0)
    f.BorderSizePixel = 0
    f.Parent = par
    if r ~= false then mkCorner(f, r or 10) end
    return f
end

-- Lbl: text label (fills parent by default, transparent bg)
local function Lbl(par, txt, col, sz, fnt, ax, ay)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Text      = txt  or ""
    l.TextColor3 = col or T.Txt
    l.TextSize  = sz   or 13
    l.Font      = fnt  or Enum.Font.Gotham
    l.TextXAlignment = ax or Enum.TextXAlignment.Left
    l.TextYAlignment = ay or Enum.TextYAlignment.Center
    l.Size      = UDim2.new(1,0,1,0)
    l.BorderSizePixel = 0
    l.TextTruncate = Enum.TextTruncate.AtEnd
    l.Parent    = par
    return l
end

-- Btn: button with hover / press tweens
local function Btn(par, txt, bgCol, txtCol, sz, pos, anch, r)
    local b = Instance.new("TextButton")
    b.BackgroundColor3 = bgCol  or T.Acc
    b.Size       = sz   or UDim2.new(1,0,0,40)
    b.Position   = pos  or UDim2.new(0,0,0,0)
    b.AnchorPoint = anch or Vector2.new(0,0)
    b.Text       = txt  or ""
    b.TextColor3 = txtCol or T.Txt
    b.TextSize   = 13
    b.Font       = Enum.Font.GothamBold
    b.AutoButtonColor = false
    b.BorderSizePixel = 0
    b.Parent     = par
    mkCorner(b, r or 10)
    local base = bgCol or T.Acc
    b.MouseEnter:Connect(function()       tw(b, TI_Fast, {BackgroundColor3 = T.AccHi}) end)
    b.MouseLeave:Connect(function()       tw(b, TI_Fast, {BackgroundColor3 = base})    end)
    b.MouseButton1Down:Connect(function() tw(b, TI_Fast, {BackgroundColor3 = T.AccLo}) end)
    b.MouseButton1Up:Connect(function()   tw(b, TI_Fast, {BackgroundColor3 = T.AccHi}) end)
    return b
end

-- Tbx: text box with focus stroke animation
local function Tbx(par, ph, sz, pos)
    local t = Instance.new("TextBox")
    t.BackgroundColor3    = T.Bg3
    t.Size       = sz  or UDim2.new(1,0,0,38)
    t.Position   = pos or UDim2.new(0,0,0,0)
    t.Text       = ""
    t.PlaceholderText = ph or ""
    t.TextColor3 = T.Txt
    t.PlaceholderColor3 = T.TxtFnt
    t.TextSize   = 12
    t.Font       = Enum.Font.Gotham
    t.ClearTextOnFocus = false
    t.TextXAlignment   = Enum.TextXAlignment.Left
    t.BorderSizePixel  = 0
    t.ClipsDescendants = true
    t.Parent     = par
    mkCorner(t, 8)
    mkPad(t, 12, 12, 0, 0)
    local st = mkStroke(t, T.Bdr, 1)
    t.Focused:Connect(function()   tw(st, TI_Fast, {Color = T.Acc}) end)
    t.FocusLost:Connect(function() tw(st, TI_Fast, {Color = T.Bdr}) end)
    return t
end

