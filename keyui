local function init()
    Protect.checkpoint("init")
    setupStorage()
    Controller.State.ResolvedAccessType = normalizeAccessType(Config.AccessType)
    Controller.Data = sanitizeData({
        username = LocalPlayer and LocalPlayer.Name or "Unknown",
        displayName = LocalPlayer and LocalPlayer.DisplayName or "Unknown",
        accessType = Config.AccessType,
        lastLogin = 0,
        lastUsedKey = "",
        discordId = "",
        nickname = "",
    })

    buildUi()
    loadIntoUi()
    bindActions()
    Controller:Open()
end

init()
return Controller
