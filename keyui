local Toasts = {}   -- active toast frames
local _toastHolder  -- set after UI built

local TOAST_TYPE_COLORS = {
    Success = C.Success,
    Error   = C.Error,
    Warning = C.Warning,
    Info    = C.Info,
}

local function ShowToast(message, kind, duration)
    if not _toastHolder then return end
    kind     = kind     or "Info"
    duration = duration or 3

    -- Container
    local toast = UI.Frame(_toastHolder, {
        Name  = "Toast_" .. tick(),
        Color = C.Panel,
        Size  = UDim2.new(1,0,0,44),
        Corner = 8,
    })
    Stroke(toast, TOAST_TYPE_COLORS[kind] or C.Accent, 1, 0.4)
    Padding(toast, nil, 0, 0, 10, 10)

    -- Accent bar on left
    local bar = UI.Frame(toast, {
        Name  = "Bar",
        Color = TOAST_TYPE_COLORS[kind] or C.Accent,
        Size  = UDim2.new(0,3,1,0),
        Position = UDim2.new(0,0,0,0),
        Corner = 3,
    })

    -- Message text
    UI.Label(toast, {
        Name      = "Msg",
        Text      = message,
        TextColor = C.Text,
        TextSize  = 12,
        Font      = Enum.Font.Gotham,
        Size      = UDim2.new(1,-18,1,0),
        Position  = UDim2.new(0,14,0,0),
        AlignX    = Enum.TextXAlignment.Left,
    })

    -- Slide in
    toast.Position = UDim2.new(1.2, 0, 0, 0)
    Tween(toast, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Position = UDim2.new(0,0,0,0)})

    table.insert(Toasts, toast)

    -- Auto dismiss
    task.delay(duration, function()
        if toast and toast.Parent then
            Tween(toast, FadeInfo, {
                Position = UDim2.new(1.2,0,0,0),
                BackgroundTransparency = 1
            })
            task.delay(0.3, function()
                pcall(function() toast:Destroy() end)
            end)
        end
    end)
end

