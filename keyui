-- STORAGE
----------------------------------------------------------------

local function storagePath()
    return string.format("%s/%s", Config.Storage.Folder, Config.Storage.File)
end

local function setupStorage()
    local hasRead = typeof(readfile) == "function"
    local hasWrite = typeof(writefile) == "function"
    Controller.State.StorageAvailable = hasRead and hasWrite

    if not Controller.State.StorageAvailable then
        return
    end

    local folder = Config.Storage.Folder
    if typeof(isfolder) == "function" then
        local ok, exists = pcall(isfolder, folder)
        if ok and not exists and typeof(makefolder) == "function" then
            pcall(makefolder, folder)
        end
    elseif typeof(makefolder) == "function" then
        pcall(makefolder, folder)
    end
end

local function loadData()
    if not Controller.State.StorageAvailable then
        return sanitizeData({
            username = LocalPlayer and LocalPlayer.Name or "Unknown",
            displayName = LocalPlayer and LocalPlayer.DisplayName or "Unknown",
            accessType = Config.AccessType,
            lastLogin = 0,
            lastUsedKey = "",
            discordId = "",
            nickname = "",
            rememberMe = Config.RememberMeDefault,
        })
    end

    local path = storagePath()
    local exists = true

    if typeof(isfile) == "function" then
        local ok, out = pcall(isfile, path)
        exists = ok and out or false
    end

    if not exists then
        return sanitizeData({
            username = LocalPlayer and LocalPlayer.Name or "Unknown",
            displayName = LocalPlayer and LocalPlayer.DisplayName or "Unknown",
            accessType = Config.AccessType,
            lastLogin = 0,
            lastUsedKey = "",
            discordId = "",
            nickname = "",
            rememberMe = Config.RememberMeDefault,
        })
    end

    local okRead, content = pcall(readfile, path)
    if not okRead or typeof(content) ~= "string" or content == "" then
        return sanitizeData({
            username = LocalPlayer and LocalPlayer.Name or "Unknown",
            displayName = LocalPlayer and LocalPlayer.DisplayName or "Unknown",
            accessType = Config.AccessType,
            lastLogin = 0,
            lastUsedKey = "",
            discordId = "",
            nickname = "",
            rememberMe = Config.RememberMeDefault,
        })
    end

    local okDecode, decoded = pcall(function()
        return HttpService:JSONDecode(content)
    end)

    if not okDecode or typeof(decoded) ~= "table" then
        return sanitizeData({
            username = LocalPlayer and LocalPlayer.Name or "Unknown",
            displayName = LocalPlayer and LocalPlayer.DisplayName or "Unknown",
            accessType = Config.AccessType,
            lastLogin = 0,
            lastUsedKey = "",
            discordId = "",
            nickname = "",
            rememberMe = Config.RememberMeDefault,
        })
    end

    Controller.State.LoadedData = true
    return sanitizeData(decoded)
end

local function saveData(data)
    data = sanitizeData(data)

    if not Controller.State.StorageAvailable then
        return false, "Local file functions are unavailable in this environment."
    end

    local okEncode, encoded = pcall(function()
        return HttpService:JSONEncode(data)
    end)

    if not okEncode then
        return false, "Failed to encode user data."
    end

    local okWrite = pcall(writefile, storagePath(), encoded)
    if not okWrite then
        return false, "Failed to write user data."
    end

    Controller.State.LoadedData = true
    Controller.Data = data
    return true, "User data saved."
end

local function clearSavedStorage()
    if not Controller.State.StorageAvailable then
        Controller.State.LoadedData = false
        return
    end

    local path = storagePath()
    if typeof(delfile) == "function" then
        local okExists, exists = pcall(function()
            return typeof(isfile) == "function" and isfile(path)
        end)
        if okExists and exists then
            pcall(delfile, path)
        end
    else
        local blank = sanitizeData({
            username = LocalPlayer and LocalPlayer.Name or "Unknown",
            displayName = LocalPlayer and LocalPlayer.DisplayName or "Unknown",
            accessType = Config.AccessType,
            lastLogin = 0,
            lastUsedKey = "",
            discordId = "",
            nickname = "",
            rememberMe = false,
        })
        local okEncode, encoded = pcall(function()
            return HttpService:JSONEncode(blank)
        end)
        if okEncode then
            pcall(writefile, path, encoded)
        end
    end

    Controller.State.LoadedData = false
end

