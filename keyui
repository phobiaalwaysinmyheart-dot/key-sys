--[[
    KeySystem:Init([callback])

    Builds the UI and waits for the user to authenticate.
    Returns a result table:
        {
            Passed     : bool,
            AccessType : string,  -- "Free" | "Keyless" | "Premium" | "Lifetime"
            DiscordID  : string,
            Username   : string,
            Key        : string,  -- only set in Free mode
        }

    Optionally pass a callback(result) instead of yielding.
--]]
function KeySystem:Init(callback)
    _resolved = false
    _result   = {
        Passed     = false,
        AccessType = CONFIG.AccessMode,
        DiscordID  = "",
        Username   = LP.Name,
        Key        = "",
    }

    BuildUI()

    if callback then
        -- Non-blocking: poll for resolution
        task.spawn(function()
            while not _resolved do task.wait(0.1) end
            callback(_result)
        end)
        return
    end

    -- Blocking yield
    while not _resolved do task.wait(0.1) end
    return _result
end

-- Expose CONFIG so callers can override before calling Init
KeySystem.Config = CONFIG

return KeySystem
