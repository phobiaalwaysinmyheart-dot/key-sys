local function applyDataToInputs(data)
    Controller.Gui.DiscordBox.Text = data.discordId or ""
    Controller.Gui.UsernameBox.Text = LocalPlayer and LocalPlayer.Name or data.username or "Unknown"
    Controller.Gui.KeyBox.Text = data.lastUsedKey or ""
end

local function syncRememberToggle()
    if not Controller.Gui.RememberBox then
        return
    end

    local enabled = Controller.State.RememberMe
    Controller.Gui.RememberBox.BackgroundColor3 = enabled and Theme.Accent2 or Theme.Surface3
    Controller.Gui.RememberTick.Visible = enabled
    Controller.Gui.RememberLabel.TextColor3 = enabled and Theme.Text or Theme.TextDim
end

local function refreshModeUi()
    local access = Controller.State.ResolvedAccessType
    local needs = needsKey()

    Controller.Gui.KeyHolder.Visible = needs
    Controller.Gui.GetKeyButton.Visible = Config.EnableFreeMode and access == "Free"
    Controller.Gui.AccessTypeValue.Text = access
    Controller.Gui.SubscriptionValue.Text = resolveSubscriptionText()
    Controller.Gui.HeaderAccessBadge.Text = "Access Type: " .. access
    Controller.Gui.HeaderSubBadge.Text = "Subscription: " .. resolveSubscriptionText()

    -- authCard always fills the full left column; just show/hide key field
    if needs then
        Controller.Gui.KeyHolder.Position = UDim2.fromOffset(0, 208)
        Controller.Gui.HelperText.Position = UDim2.fromOffset(0, 290)
        Controller.Gui.GetKeyButton.Size = UDim2.fromOffset(144, 38)
    else
        Controller.Gui.HelperText.Position = UDim2.fromOffset(0, 208)
        Controller.Gui.GetKeyButton.Size = UDim2.fromOffset(0, 38)
    end

    if access == "Keyless" then
        Controller.Gui.HelperText.Visible = false
    elseif access == "Free" then
        Controller.Gui.HelperText.Visible = false
    else
        Controller.Gui.HelperText.Visible = false
    end

    syncRememberToggle()
end

local function refreshInfo()
    local data = Controller.Data
    Controller.Gui.AccessTypeValue.Text = Controller.State.ResolvedAccessType
    Controller.Gui.SubscriptionValue.Text = resolveSubscriptionText()
    Controller.Gui.DataStateValue.Text = Controller.State.LoadedData and "Loaded" or "Ready"
    Controller.Gui.RobloxValue.Text = data.username ~= "" and data.username or "-"
    Controller.Gui.DiscordValue.Text = data.discordId ~= "" and data.discordId or "-"
    Controller.Gui.LoginValue.Text = formatTimestamp(data.lastLogin)
    if Controller.Gui.ExecValue then
        Controller.Gui.ExecValue.Text = tostring(ExecutionCount)
    end
    if Controller.Gui.ExecutorValue then
        Controller.Gui.ExecutorValue.Text = detectExecutor()
    end
    if Controller.Gui.PlatformValue then
        Controller.Gui.PlatformValue.Text = detectPlatform()
    end
    if Controller.Gui.MembershipValue then
        Controller.Gui.MembershipValue.Text = getMembership()
    end
    if Controller.Gui.AccountAgeValue then
        Controller.Gui.AccountAgeValue.Text = getAccountAge()
    end
end

local function loadIntoUi()
    Controller.Data = loadData()
    Controller.State.ResolvedAccessType = normalizeAccessType(Controller.Data.accessType or Config.AccessType)
    Controller.State.RememberMe = Controller.Data.rememberMe ~= false
    applyDataToInputs(Controller.Data)
    refreshModeUi()
    refreshInfo()

    if Controller.State.LoadedData then
        Controller.Gui.HeaderMiniStatus.Text = "User Data Loaded"
        Controller.Gui.HeaderMiniStatus.TextColor3 = Theme.Success
        setStatus("User data loaded successfully.", "success")
    else
        if Controller.State.StorageAvailable then
            Controller.Gui.HeaderMiniStatus.Text = "First-time setup"
            Controller.Gui.HeaderMiniStatus.TextColor3 = Theme.Info
            setStatus("Ready for setup.", "info")
        else
            Controller.Gui.HeaderMiniStatus.Text = "Running without local storage"
            Controller.Gui.HeaderMiniStatus.TextColor3 = Theme.Warning
            setStatus("File functions unavailable. Running without local storage.", "warning")
        end
    end
end

