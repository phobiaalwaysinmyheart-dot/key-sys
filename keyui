local function collectPayload()
    local payload = sanitizeData({
        lastUsedKey = Controller.Gui.KeyBox.Text,
        discordId = Controller.Gui.DiscordBox.Text,
        nickname = "",
        username = LocalPlayer and LocalPlayer.Name or "Unknown",
        displayName = LocalPlayer and LocalPlayer.DisplayName or "Unknown",
        accessType = Controller.State.ResolvedAccessType,
        lastLogin = getTimestamp(),
        rememberMe = Controller.State.RememberMe,
    })
    return payload
end

local function resetSavedData()
    local blank = sanitizeData({
        username = LocalPlayer and LocalPlayer.Name or "Unknown",
        displayName = LocalPlayer and LocalPlayer.DisplayName or "Unknown",
        accessType = Controller.State.ResolvedAccessType,
        lastLogin = 0,
        lastUsedKey = "",
        discordId = "",
        nickname = "",
        rememberMe = Config.RememberMeDefault,
    })

    if Controller.State.StorageAvailable then
        local okEncode, encoded = pcall(function()
            return HttpService:JSONEncode(blank)
        end)
        if okEncode then
            pcall(writefile, storagePath(), encoded)
        end
    end

    Controller.Data = blank
    Controller.State.LoadedData = false
    applyDataToInputs(blank)
    refreshInfo()
    Controller.Gui.HeaderMiniStatus.Text = "Local data reset"
    Controller.Gui.HeaderMiniStatus.TextColor3 = Theme.Warning
    setStatus("Saved data has been reset.", "warning")
    notify("warning", "Local data reset.")
end

local function handleSave()
    local payload = collectPayload()

    if Config.RequireDiscord and not isValidDiscord(payload.discordId) then
        Controller.Gui.HelperText.Text = Config.DiscordErrorText
        Controller.Gui.HelperText.TextColor3 = Theme.Error
        Controller.Gui.HeaderMiniStatus.Text = "Discord validation failed"
        Controller.Gui.HeaderMiniStatus.TextColor3 = Theme.Error
        setStatus("Cannot save invalid Discord data.", "error")
        notify("error", Config.DiscordErrorText)
        return
    end

    local ok, msg = saveData(payload)
    if ok then
        refreshInfo()
        Controller.Gui.HeaderMiniStatus.Text = "User Data Loaded"
        Controller.Gui.HeaderMiniStatus.TextColor3 = Theme.Success
        setStatus("Data saved locally.", "success")
        notify("success", msg or "User data saved.")
    else
        Controller.Gui.HeaderMiniStatus.Text = "Save failed"
        Controller.Gui.HeaderMiniStatus.TextColor3 = Theme.Error
        setStatus(msg or "Save failed.", "error")
        notify("error", msg or "Save failed.")
    end
end

local function handleCopyDiscord()
    local value = trim(Config.CopyDiscordValue)
    if value == "" then
        value = trim(Controller.Gui.DiscordBox.Text)
    end

    if value == "" then
        notify("warning", "Nothing to copy.")
        return
    end

    if typeof(setclipboard) == "function" then
        Protect.api("setclipboard")
        setclipboard(value)
        setStatus("Discord value copied.", "success")
        notify("success", "Copied to clipboard.")
    else
        setStatus("Clipboard function unavailable.", "warning")
        notify("warning", "Clipboard is not supported in this environment.")
    end
end

local function handleGetKey()
    if not Config.EnableFreeMode then
        notify("warning", "Free mode is disabled.")
        return
    end

    if typeof(Config.OnGetKey) == "function" then
        local okCall, result = pcall(Config.OnGetKey, Controller)
        if okCall and type(result) == "string" and result ~= "" and typeof(setclipboard) == "function" then
            setclipboard(result)
            setStatus("Key link copied.", "success")
            notify("success", "Key link copied to clipboard.")
            return
        end
    end

    if typeof(setclipboard) == "function" then
        setclipboard("https://your-key-link-here")
        setStatus("Placeholder key link copied.", "info")
        notify("info", "Placeholder key link copied.")
    else
        setStatus("No key handler configured.", "warning")
        notify("warning", "Add your own key link handler in Config.OnGetKey.")
    end
end

local function handleRememberToggle()
    Controller.State.RememberMe = not Controller.State.RememberMe
    syncRememberToggle()

    if Controller.State.RememberMe then
        setStatus("Remember Me enabled.", "info")
    else
        setStatus("Remember Me disabled for this session.", "warning")
    end
end

local function handleContinue()
    local payload = collectPayload()

    if Config.RequireDiscord and not isValidDiscord(payload.discordId) then
        Controller.Gui.HelperText.Text = Config.DiscordErrorText
        Controller.Gui.HelperText.TextColor3 = Theme.Error
        Controller.Gui.HeaderMiniStatus.Text = "Discord validation failed"
        Controller.Gui.HeaderMiniStatus.TextColor3 = Theme.Error
        setStatus("Discord validation failed.", "error")
        notify("error", Config.DiscordErrorText)
        return
    end

    if needsKey() then
        local okKey, keyMessage = Config.ValidateKey(payload.lastUsedKey, payload, Config)
        if not okKey then
            Controller.Gui.HelperText.Text = keyMessage or "Invalid key."
            Controller.Gui.HelperText.TextColor3 = Theme.Error
            Controller.Gui.HeaderMiniStatus.Text = "Key validation failed"
            Controller.Gui.HeaderMiniStatus.TextColor3 = Theme.Error
            setStatus("Authentication failed.", "error")
            notify("error", keyMessage or "Invalid key.")
            return
        end
    end

    local success, message, resolvedAccess = true, "Authentication complete.", nil

    if typeof(Config.OnAuthenticate) == "function" then
        local okCall, a, b, c = pcall(Config.OnAuthenticate, payload, Controller)
        if not okCall then
            success = false
            message = tostring(a)
        else
            success = a ~= false
            message = b or (success and "Authentication complete." or "Authentication failed.")
            resolvedAccess = c
        end
    end

    if not success then
        Controller.Gui.HeaderMiniStatus.Text = "Authentication failed"
        Controller.Gui.HeaderMiniStatus.TextColor3 = Theme.Error
        setStatus(message or "Authentication failed.", "error")
        notify("error", message or "Authentication failed.")
        return
    end

    if resolvedAccess then
        Controller.State.ResolvedAccessType = normalizeAccessType(resolvedAccess)
        payload.accessType = Controller.State.ResolvedAccessType
    end

    Controller.Data = payload
    if Controller.State.RememberMe then
        saveData(payload)
    else
        clearSavedStorage()
    end
    refreshModeUi()
    refreshInfo()

    Controller.Gui.HelperText.Text = Controller.State.ResolvedAccessType == "Keyless"
        and "No key is required for this access mode."
        or "Authentication complete."
    Controller.Gui.HelperText.TextColor3 = Theme.Success
    Controller.Gui.HeaderMiniStatus.Text = Controller.State.RememberMe and "User Data Loaded" or "Session Ready"
    Controller.Gui.HeaderMiniStatus.TextColor3 = Theme.Success
    setStatus(Controller.State.RememberMe and (message or "Authentication complete.") or "Authentication complete. Remember Me is disabled for this session.", "success")
    notify("success", message or "Authentication complete.")

    if typeof(Config.OnContinue) == "function" then
        incrementExecution()
        if Controller.Gui.ExecValue then
            Controller.Gui.ExecValue.Text = tostring(ExecutionCount)
        end
        local ok, err = pcall(Config.OnContinue, payload, Controller)
        if not ok then
            print("[Hyperion] OnContinue error:", err)
        end
    end
end

----------------------------------------------------------------
-- OPEN / CLOSE
----------------------------------------------------------------

function Controller:Open()
    if self.State.Open then
        return
    end
    self.State.Open = true

    local window = self.Gui.Window
    local overlay = self.Gui.Overlay
    if not window or not overlay then
        return
    end

    overlay.BackgroundTransparency = 1
    window.Position = UDim2.fromScale(0.5, 0.535)
    window.Size = UDim2.fromOffset(910, 540)

    tween(overlay, 0.22, {BackgroundTransparency = 0.36})
    tween(window, 0.3, {Position = UDim2.fromScale(0.5, 0.5), Size = UDim2.fromOffset(980, 570)})
end

function Controller:Close()
    if not self.State.Open then
        return
    end
    self.State.Open = false

    local window = self.Gui.Window
    local overlay = self.Gui.Overlay
    if not window or not overlay then
        return
    end

    tween(overlay, 0.18, {BackgroundTransparency = 1})
    tween(window, 0.18, {Position = UDim2.fromScale(0.5, 0.535), Size = UDim2.fromOffset(910, 540)})
end

function Controller:Destroy()
    Protect.stop()
    for _, c in ipairs(self.Connections) do
        pcall(function() c:Disconnect() end)
    end
    if self.Gui.Gui then
        self.Gui.Gui:Destroy()
    end
end

function Controller:SetAccessType(accessType, subscription)
    self.State.ResolvedAccessType = normalizeAccessType(accessType)
    if subscription then
        Config.Subscription = subscription
    end
    refreshModeUi()
    refreshInfo()
end

