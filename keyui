        UDim2.new(1,0,0,1), nil, nil, false, 1)
    CDivWrap.LayoutOrder = 2
    Frm(CDivWrap, T.Bdr, UDim2.new(1,0,1,0), nil, nil, false, 0.65)

    -- ── Auth section (keyless msg OR key input) ──────────────────
    local AuthWrap = Frm(Card, Color3.new(0,0,0),
        UDim2.new(1,0,0,30), nil, nil, false, 1)
    AuthWrap.LayoutOrder = 3

    local _keyBox

    if CONFIG.AccessMode == "Free" then
        AuthWrap.Size = UDim2.new(1,0,0,58)
        -- label
        local kLbl = Lbl(AuthWrap, "ENTER KEY", T.TxtFnt, 9,
            Enum.Font.GothamBold, Enum.TextXAlignment.Left, Enum.TextYAlignment.Top)
        kLbl.Size     = UDim2.new(1,0,0,14)
        kLbl.Position = UDim2.new(0,0,0,0)
        -- input
        _keyBox = Tbx(AuthWrap, "HYPERION-XXXX-XXXX-XXXX",
            UDim2.new(1,0,0,36), UDim2.new(0,0,0,16))
        _keyBox.Font    = Enum.Font.Code
        _keyBox.TextSize = 12
    else
        -- Tiny coloured dot + short message
        local dot = Frm(AuthWrap, badgeCol,
            UDim2.new(0,6,0,6),
            UDim2.new(0,0,0,12), nil, 3, 0.4)
        mkStroke(dot, badgeCol, 1, 0.1)
        local msgs = {
            Keyless="No key required.",
            Premium="Premium access verified.",
            Lifetime="Lifetime access verified.",
        }
        local authLbl = Lbl(AuthWrap, msgs[CONFIG.AccessMode] or "Access granted.",
            T.TxtSub, 12, Enum.Font.Gotham,
            Enum.TextXAlignment.Left, Enum.TextYAlignment.Center)
        authLbl.Size     = UDim2.new(1,-14,1,0)
        authLbl.Position = UDim2.new(0,14,0,0)
    end

    -- ── Discord ID input (only on first run) ─────────────────────
    local _discordBox, _discordErr
    local DiscordWrap = Frm(Card, Color3.new(0,0,0),
        UDim2.new(1,0,0,56), nil, nil, false, 1)
    DiscordWrap.LayoutOrder = 4
    DiscordWrap.Visible     = false

    local dLbl = Lbl(DiscordWrap, "DISCORD ID", T.TxtFnt, 9,
        Enum.Font.GothamBold, Enum.TextXAlignment.Left, Enum.TextYAlignment.Top)
    dLbl.Size     = UDim2.new(1,0,0,14)
    dLbl.Position = UDim2.new(0,0,0,0)

    _discordBox = Tbx(DiscordWrap, "e.g. 123456789012345678",
        UDim2.new(1,0,0,36), UDim2.new(0,0,0,16))

    -- Error label (sits outside card list, shown inline when needed)
    local _errWrap = Frm(Card, Color3.new(0,0,0),
        UDim2.new(1,0,0,0), nil, nil, false, 1)
    _errWrap.AutomaticSize = Enum.AutomaticSize.Y
    _errWrap.LayoutOrder   = 5
    _errWrap.Visible       = false

    _discordErr = Lbl(_errWrap, "", T.Red, 10, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, Enum.TextYAlignment.Top)
    _discordErr.Size     = UDim2.new(1,0,0,16)
    _discordErr.Position = UDim2.new(0,0,0,0)

    -- ════════════════════════════════════════════════════════════
    -- BUTTON ROW
    -- ════════════════════════════════════════════════════════════
    local BtnWrap = Frm(Win, Color3.new(0,0,0),
        UDim2.new(1,-32,0,40),
        UDim2.new(0,16,0,0), nil, false, 1)
    BtnWrap.LayoutOrder = 4
    mkListLayout(BtnWrap,
        Enum.FillDirection.Horizontal,
        Enum.HorizontalAlignment.Left,
        Enum.VerticalAlignment.Center, 8)

    -- Continue (primary)
    local ContinueBtn = Btn(BtnWrap,
        CONFIG.AccessMode == "Keyless" and "Continue  →" or "Validate  →",
        T.Acc, Color3.new(1,1,1),
        UDim2.new(0,0,0,40), nil, nil, 10)
    ContinueBtn.LayoutOrder   = 1
    ContinueBtn.AutomaticSize = Enum.AutomaticSize.X
    mkPad(ContinueBtn, 18,18,0,0)
    mkGrad(ContinueBtn, ColorSequence.new({
        ColorSequenceKeypoint.new(0, T.AccHi),
        ColorSequenceKeypoint.new(1, T.AccLo),
    }), 135)

    -- Save (ghost)
    local SaveBtn = Btn(BtnWrap, "Save", T.Bg3, T.TxtSub,
        UDim2.new(0,64,0,40), nil, nil, 10)
    SaveBtn.LayoutOrder   = 2
    SaveBtn.AutomaticSize = Enum.AutomaticSize.X
    mkPad(SaveBtn, 14,14,0,0)
    mkStroke(SaveBtn, T.Bdr, 1)

    -- Reset (destructive ghost)
    local ResetBtn = Btn(BtnWrap, "Reset", T.Bg3, T.TxtSub,
        UDim2.new(0,64,0,40), nil, nil, 10)
    ResetBtn.LayoutOrder   = 3
    ResetBtn.AutomaticSize = Enum.AutomaticSize.X
    mkPad(ResetBtn, 14,14,0,0)
    mkStroke(ResetBtn, Color3.fromRGB(65,22,28), 1)
    ResetBtn.MouseEnter:Connect(function()
        tw(ResetBtn, TI_Fast, {BackgroundColor3=Color3.fromRGB(55,16,22), TextColor3=T.Red})
    end)
    ResetBtn.MouseLeave:Connect(function()
        tw(ResetBtn, TI_Fast, {BackgroundColor3=T.Bg3, TextColor3=T.TxtSub})
    end)

    -- Get Key (Free mode only)
    if CONFIG.AccessMode == "Free" then
        local GKBtn = Btn(BtnWrap, "Get Key ↗", T.Bg3, T.AccHi,
            UDim2.new(0,80,0,40), nil, nil, 10)
        GKBtn.LayoutOrder   = 4
        GKBtn.AutomaticSize = Enum.AutomaticSize.X
        mkPad(GKBtn, 14,14,0,0)
        mkStroke(GKBtn, T.AccLo, 1)
        GKBtn.MouseButton1Click:Connect(function()
            Toast("Link copied to clipboard.", "Info", 3)
            pcall(function()
                if setclipboard then setclipboard(CONFIG.GetKeyURL) end
            end)
        end)
    end

    -- ════════════════════════════════════════════════════════════
    -- FOOTER
    -- ════════════════════════════════════════════════════════════
    local Footer = Frm(Win, Color3.new(0,0,0),
        UDim2.new(1,-32,0,20),
        UDim2.new(0,16,0,0), nil, false, 1)
    Footer.LayoutOrder = 5

    Lbl(Footer, "Build "..CONFIG.Build, T.TxtFnt, 9, Enum.Font.Gotham)
    local byLbl = Lbl(Footer, "by Phobia", T.TxtFnt, 9,
        Enum.Font.Gotham, Enum.TextXAlignment.Right)
    byLbl.Size = UDim2.new(1,0,1,0)

    -- ════════════════════════════════════════════════════════════
    -- TOAST HOLDER (overlays window bottom)
    -- ════════════════════════════════════════════════════════════
    _toastHolder = Frm(Screen, Color3.new(0,0,0),
        UDim2.new(0,380,0,160),
        UDim2.new(0.5,0,1,-20),
        Vector2.new(0.5,1),
        false, 1)
    _toastHolder.ClipsDescendants = false
    _toastHolder.ZIndex = 30

    mkListLayout(_toastHolder,
        Enum.FillDirection.Vertical,
        Enum.HorizontalAlignment.Center,
        Enum.VerticalAlignment.Bottom, 4)

    -- ════════════════════════════════════════════════════════════
    -- § 11 · LOGIC & CALLBACKS
    -- ════════════════════════════════════════════════════════════

    local function ValidateDiscord(id)
        id = (id or ""):match("^%s*(.-)%s*$")
        return id:match(CONFIG.DiscordPattern) ~= nil
    end

    local function CollectAndSave(discID)
        Store.save({
            discordID   = discID or _result.DiscordID,
            username    = LP.Name,
            displayName = LP.DisplayName,
            accessType  = CONFIG.AccessMode,
            lastLogin   = tostring(os.time()),
            lastKey     = _keyBox and _keyBox.Text or "",
        })
    end

    local function Resolve(accessType)
        if _resolved then return end
        _result.Passed     = true
        _result.AccessType = accessType or CONFIG.AccessMode
        CollectAndSave()
        task.delay(0.9, CloseScreen)
    end

    -- ── Load saved data ──────────────────────────────────────────
    local saved         = Store.load()
    local hasSavedDisc  = (saved.discordID and saved.discordID ~= "")

    if hasSavedDisc then
        _result.DiscordID = saved.discordID
        HandleLbl.Text    = "@"..LP.Name.."  ·  "..saved.discordID
    end
    if _keyBox and saved.lastKey and saved.lastKey ~= "" then
        _keyBox.Text = saved.lastKey
    end
    if CONFIG.RequireDiscord and not hasSavedDisc then
        DiscordWrap.Visible = true
        if _discordBox and saved.discordID then
            _discordBox.Text = saved.discordID
        end
    end

    -- ── Continue ─────────────────────────────────────────────────
    ContinueBtn.MouseButton1Click:Connect(function()
        -- Discord validation
        if CONFIG.RequireDiscord and not hasSavedDisc then
            local raw = (_discordBox.Text or ""):match("^%s*(.-)%s*$")
            if not ValidateDiscord(raw) then
                _discordErr.Text    = "⚠  Must be 17–19 digits"
                _errWrap.Visible    = true
                tw(_discordBox, TI_Fast, {BackgroundColor3=Color3.fromRGB(52,15,20)})
                task.delay(0.35, function()
                    tw(_discordBox, TI_Fast, {BackgroundColor3=T.Bg3})
                end)
                Toast("Enter a valid Discord ID.", "Error", 3)
                return
            end
            _errWrap.Visible  = false
            _result.DiscordID = raw
            HandleLbl.Text    = "@"..LP.Name.."  ·  "..raw
        end

        -- Key validation (Free mode)
        if CONFIG.AccessMode == "Free" then
            local key = (_keyBox and _keyBox.Text or ""):match("^%s*(.-)%s*$")
            if #CONFIG.ValidKeys > 0 then
                local ok = false
                for _, vk in ipairs(CONFIG.ValidKeys) do
                    if vk == key then ok = true break end
                end
                if not ok then
                    tw(_keyBox, TI_Fast, {BackgroundColor3=Color3.fromRGB(52,15,20)})
                    task.delay(0.35, function()
                        tw(_keyBox, TI_Fast, {BackgroundColor3=T.Bg3})
                    end)
                    Toast("Invalid key.", "Error", 3)
                    return
                end
            end
            _result.Key = key
            Toast("Key accepted!", "Success", 2)
        else
            Toast("Welcome, "..LP.DisplayName.."!", "Success", 2)
        end

        Resolve(CONFIG.AccessMode)
    end)

    -- ── Save ─────────────────────────────────────────────────────
    SaveBtn.MouseButton1Click:Connect(function()
        CollectAndSave(_result.DiscordID)
        Toast("Data saved.", "Success", 2)
    end)

    -- ── Reset ────────────────────────────────────────────────────
    ResetBtn.MouseButton1Click:Connect(function()
        Store.clear()
        _result.DiscordID = ""
        HandleLbl.Text    = "@"..LP.Name
        if _keyBox    then _keyBox.Text    = "" end
        if _discordBox then _discordBox.Text = "" end
        DiscordWrap.Visible = CONFIG.RequireDiscord
        hasSavedDisc = false
        Toast("Data cleared.", "Warning", 2)
    end)

    return Screen
end

-- ════════════════════════════════════════════════════════════════
-- § 12 · PUBLIC API
-- ════════════════════════════════════════════════════════════════

function KeySystem:Init(callback)
    _resolved = false
    _result   = {
        Passed     = false,
        AccessType = CONFIG.AccessMode,
        DiscordID  = "",
        Username   = LP.Name,
        Key        = "",
    }
    BuildUI()

    if callback then
        task.spawn(function()
            while not _resolved do task.wait(0.1) end
            callback(_result)
        end)
        return
    end

    while not _resolved do task.wait(0.1) end
    return _result
end

KeySystem.Config = CONFIG
return KeySystem
