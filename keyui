    -- Helper: validate Discord ID format
    local function ValidateDiscordID(id)
        if type(id) ~= "string" then return false end
        id = id:match("^%s*(.-)%s*$") -- trim
        return id:match(CONFIG.DiscordIDPattern) ~= nil
    end

    -- Helper: format a timestamp to readable date
    local function FormatTimestamp(ts)
        ts = tonumber(ts)
        if not ts then return "Unknown" end
        -- Simple relative display (can't do full date without os.date in Luau)
        local diff = os.time() - ts
        if diff < 60    then return "Just now" end
        if diff < 3600  then return math.floor(diff/60)  .. "m ago" end
        if diff < 86400 then return math.floor(diff/3600) .. "h ago" end
        return math.floor(diff/86400) .. "d ago"
    end

    -- Populate UI with saved/current user data
    local function PopulateUserInfo(data)
        local discordID = data.discordID or ""
        DiscordValueLabel.Text = (discordID ~= "") and discordID or "—"
        UsernameValueLabel.Text = LP.DisplayName .. " (@" .. LP.Name .. ")"

        if data.accessType then
            AccessTypeValue.Text = data.accessType
        end
        if data.discordID and data.discordID ~= "" then
            DataLoadedChip.Visible = true
        end
        _result.DiscordID = discordID
        _result.Username  = LP.Name
    end

    -- Collect and save all current user data
    local function CollectAndSave()
        local dataToSave = {
            discordID   = _result.DiscordID,
            username    = LP.Name,
            displayName = LP.DisplayName,
            accessType  = _result.AccessType,
            lastLogin   = tostring(os.time()),
        }
        if _keyBox then
            dataToSave.lastKey = _keyBox.Text
        end
        local ok = Storage.Save(dataToSave)
        if ok then
            ShowToast("Data saved successfully.", "Success", 3)
            SetStatus("User Data Loaded", C.Success)
            DataLoadedChip.Visible = true
        else
            ShowToast("Could not save — executor may not support file IO.", "Warning", 4)
        end
    end

    -- Resolve with success
    local function Resolve(accessType)
        if _resolved then return end
        _resolved = true
        _orbRunning = false
        _result.Passed     = true
        _result.AccessType = accessType or CONFIG.AccessMode
        CollectAndSave()
        -- Animate out
