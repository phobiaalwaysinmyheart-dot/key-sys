local Storage = {}

-- Safely check if executor supports file functions
local _hasFS = (typeof(isfile) == "function") and
               (typeof(writefile) == "function") and
               (typeof(readfile) == "function")

local _hasFolderFS = _hasFS and (typeof(isfolder) == "function") and
                                (typeof(makefolder) == "function")

-- Get the full file path for storage
local function _storagePath()
    return CONFIG.StorageFolder .. "/" .. CONFIG.StorageFile
end

-- Ensure the storage folder exists
local function _ensureFolder()
    if not _hasFolderFS then return end
    pcall(function()
        if not isfolder(CONFIG.StorageFolder) then
            makefolder(CONFIG.StorageFolder)
        end
    end)
end

-- Encode a table to JSON-like string (simple, no external lib needed)
local function _encode(data)
    local parts = {}
    for k, v in pairs(data) do
        local vStr
        if type(v) == "string" then
            vStr = '"' .. tostring(v):gsub('"', '\\"') .. '"'
        elseif type(v) == "number" or type(v) == "boolean" then
            vStr = tostring(v)
        else
            vStr = '"' .. tostring(v) .. '"'
        end
        parts[#parts + 1] = '"' .. tostring(k) .. '":' .. vStr
    end
    return "{" .. table.concat(parts, ",") .. "}"
end

-- Decode a simple JSON-like string back to a table
local function _decode(str)
    local result = {}
    if type(str) ~= "string" then return result end
    -- string fields
    for k, v in str:gmatch('"([%w_]+)"%s*:%s*"([^"]*)"') do
        result[k] = v
    end
    -- number/bool fields
    for k, v in str:gmatch('"([%w_]+)"%s*:%s*([%d%.%-]+)') do
        result[k] = tonumber(v) or v
    end
    for k, v in str:gmatch('"([%w_]+)"%s*:%s*(true)') do
        result[k] = true
    end
    for k, v in str:gmatch('"([%w_]+)"%s*:%s*(false)') do
        result[k] = false
    end
    return result
end

-- Load user data from disk; returns {} if unavailable or corrupt
function Storage.Load()
    if not _hasFS then return {} end
    local ok, raw = pcall(function()
        local path = _storagePath()
        if isfile(path) then
            return readfile(path)
        end
        return nil
    end)
    if not ok or not raw then return {} end
    local data = _decode(raw)
    -- Sanitise: only keep expected keys with string/number values
    local safe = {}
    local allowed = {lastKey=1, discordID=1, username=1, displayName=1,
                     accessType=1, lastLogin=1}
    for k, v in pairs(data) do
        if allowed[k] and (type(v) == "string" or type(v) == "number") then
            safe[k] = tostring(v)
        end
    end
    return safe
end

-- Save user data to disk
function Storage.Save(data)
    if not _hasFS then return false end
    local ok = pcall(function()
        _ensureFolder()
        writefile(_storagePath(), _encode(data))
    end)
    return ok
end

-- Clear saved user data
function Storage.Clear()
    if not _hasFS then return false end
    local ok = pcall(function()
        if isfile(_storagePath()) then
            writefile(_storagePath(), "{}")
        end
    end)
    return ok
end

