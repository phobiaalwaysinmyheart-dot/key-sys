-- Shorthand tween
local function Tween(obj, info, goals)
    return TweenService:Create(obj, info, goals):Play()
end

local FadeInfo  = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local SlideInfo = TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
local QuickInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

-- Create a UICorner
local function Corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or CONFIG.CornerRadius)
    c.Parent = parent
    return c
end

-- Create a UIStroke border
local function Stroke(parent, color, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.Color = color or C.PanelBorder
    s.Thickness = thickness or 1
    s.Transparency = transparency or 0
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

-- Create a UIPadding
local function Padding(parent, all, top, bottom, left, right)
    local p = Instance.new("UIPadding")
    local a = UDim.new(0, all or 0)
    p.PaddingTop    = UDim.new(0, top    or (all or 0))
    p.PaddingBottom = UDim.new(0, bottom or (all or 0))
    p.PaddingLeft   = UDim.new(0, left   or (all or 0))
    p.PaddingRight  = UDim.new(0, right  or (all or 0))
    p.Parent = parent
    return p
end

-- Create a gradient UIGradient
local function Gradient(parent, colorSeq, rotation)
    local g = Instance.new("UIGradient")
    g.Color    = colorSeq
    g.Rotation = rotation or 135
    g.Parent   = parent
    return g
end

-- Base Frame constructor
function UI.Frame(parent, props)
    local f = Instance.new("Frame")
    f.BackgroundColor3 = props.Color or C.Surface
    f.BackgroundTransparency = props.Transparency or 0
    f.Size   = props.Size   or UDim2.new(1,0,1,0)
    f.Position = props.Position or UDim2.new(0,0,0,0)
    f.AnchorPoint = props.Anchor or Vector2.new(0,0)
    f.BorderSizePixel = 0
    f.ClipsDescendants = props.Clip ~= nil and props.Clip or false
    f.Name = props.Name or "Frame"
    f.Parent = parent
    if props.Corner ~= false then Corner(f, props.Corner) end
    return f
end

-- Text label constructor
function UI.Label(parent, props)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Size      = props.Size     or UDim2.new(1,0,0,20)
    l.Position  = props.Position or UDim2.new(0,0,0,0)
