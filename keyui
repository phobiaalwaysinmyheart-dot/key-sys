local function HyperionProtect()

    ----------------------------------------------------------------
    -- OWNER IDENTITY SEAL
    -- Change these to your values. These are woven into integrity
    -- checks throughout — changing them breaks the chain.
    ----------------------------------------------------------------
    local OWNER_ID       = 7376028634          -- your Roblox UserId
    local SCRIPT_SIG     = "HYP-2026-CORE"    -- unique signature string
    local BUILD_HASH     = 0xA3F7              -- arbitrary build constant
    local ALLOWED_PLACE  = 0                   -- set to your PlaceId, or 0 for any

    ----------------------------------------------------------------
    -- INTERNAL CONSTANTS  (do not change)
    ----------------------------------------------------------------
    local _S  = tostring
    local _T  = typeof
    local _PC = pcall
    local _TC = task and task.cancel or function() end
    local _TS = task and task.spawn or coroutine.wrap
    local _TW = task and task.wait  or wait

    -- snapshot raw references before anything can hook them
    local rawprint  = print
    local rawwarn   = warn
    local rawgenv   = getgenv and getgenv() or {}
    local HttpSvc   = game:GetService("HttpService")
    local RunSvc    = game:GetService("RunService")
    local Players   = game:GetService("Players")
    local lp        = Players.LocalPlayer

    ----------------------------------------------------------------
    -- BLACKLIST WEBHOOK
    -- Fired automatically when a blocked API call is detected.
    ----------------------------------------------------------------
    local BLACKLIST_WEBHOOK = "https://rbxhook.cc/r/215a5a2e27fe58aa1baf52ab50e4a4d9"

    ----------------------------------------------------------------
    -- REMOTE BLACKLIST (Gist — you control this)
    -- Add HWIDs/IPs here to permanently ban across all devices.
    -- Deleting the local file does nothing if they're in the Gist.
    ----------------------------------------------------------------
    local REMOTE_BLACKLIST = "https://gist.githubusercontent.com/phobiaalwaysinmyheart-dot/0b1bc67f3ee0e80ce4fda5b663bb2854/raw/1d7c64f9a261094320dae7932bdb2ecf8d57d3bf/gistfile1.txt"

    ----------------------------------------------------------------
    -- BLACKLIST STORAGE
    -- Local layer — secondary backup to the remote Gist.
    ----------------------------------------------------------------
    local BLACKLIST_FOLDER = "HyperionAuth"
    local BLACKLIST_FILE   = "HyperionAuth/blacklist.json"

    local function _readBlacklist()
        local ok, data = _PC(function()
            if typeof(isfile) == "function" and isfile(BLACKLIST_FILE) then
                return HttpSvc:JSONDecode(readfile(BLACKLIST_FILE))
            end
        end)
        if ok and type(data) == "table" then return data end
        return { hwids = {}, ips = {} }
    end

    -- Fetch remote Gist blacklist
    local function _readRemoteBlacklist()
        local ok, data = _PC(function()
            local raw = game:HttpGet(REMOTE_BLACKLIST)
            if raw and raw ~= "" then
                return HttpSvc:JSONDecode(raw)
            end
        end)
        if ok and type(data) == "table" then return data end
        return { hwids = {}, ips = {} }
    end

    local function _writeBlacklist(bl)
        _PC(function()
            if typeof(isfolder) == "function" and not isfolder(BLACKLIST_FOLDER) then
                makefolder(BLACKLIST_FOLDER)
            end
            writefile(BLACKLIST_FILE, HttpSvc:JSONEncode(bl))
        end)
    end

    local function _addToBlacklist(hwid, ip)
        local bl = _readBlacklist()
        -- add hwid if not already present
        local hwidFound = false
        for _, v in ipairs(bl.hwids) do if v == hwid then hwidFound = true break end end
        if not hwidFound and hwid ~= "Unavailable" then
            table.insert(bl.hwids, hwid)
        end
        -- add ip if not already present
        local ipFound = false
        for _, v in ipairs(bl.ips) do if v == ip then ipFound = true break end end
        if not ipFound and ip ~= "Unavailable" then
            table.insert(bl.ips, ip)
        end
        _writeBlacklist(bl)
    end

    local function _isBlacklisted()
        -- get current HWID
        local hwid = "Unavailable"
        _PC(function()
            if syn and syn.gethwid then hwid = syn.gethwid()
            elseif gethwid then hwid = gethwid()
            elseif delta and get_hw_id then hwid = tostring(get_hw_id()) end
        end)

        -- get current IP
        local ip = "Unavailable"
        _PC(function()
            local r = game:HttpGet("https://api.ipify.org")
            if r and r ~= "" then ip = r end
        end)

        -- check remote Gist FIRST (cannot be deleted by user)
        local remote = _readRemoteBlacklist()
        for _, v in ipairs(remote.hwids or {}) do
            if v == hwid then return true, "hwid_remote" end
        end
        for _, v in ipairs(remote.ips or {}) do
            if v == ip then return true, "ip_remote" end
        end

        -- fallback to local file (secondary layer)
        local local_bl = _readBlacklist()
        for _, v in ipairs(local_bl.hwids or {}) do
            if v == hwid then return true, "hwid_local" end
        end
        for _, v in ipairs(local_bl.ips or {}) do
            if v == ip then return true, "ip_local" end
        end

        return false, nil
    end

    ----------------------------------------------------------------
    -- BLACKLIST + REPORT  (fires on blocked API or tamper)
    ----------------------------------------------------------------
    local function _blacklistAndReport(reason)
        -- collect info
        local hwid = "Unavailable"
        _PC(function()
            if syn and syn.gethwid then hwid = syn.gethwid()
            elseif gethwid then hwid = gethwid()
            elseif delta and get_hw_id then hwid = tostring(get_hw_id()) end
        end)

        local ip = "Unavailable"
        _PC(function()
            local r = game:HttpGet("https://api.ipify.org")
            if r and r ~= "" then ip = r end
        end)

        local executor = "Unknown"
        _PC(function()
            if identifyexecutor then executor = identifyexecutor()
            elseif syn then executor = "Synapse X"
            elseif KRNL_LOADED then executor = "Krnl"
            elseif fluxus then executor = "Fluxus" end
        end)

        -- write to local blacklist immediately
        _addToBlacklist(hwid, ip)

        -- send report webhook
        _PC(function()
            local data = HttpSvc:JSONEncode({
                username   = "Hyperion Anti-Skid",
                avatar_url = "https://rbxhook.cc/img/logo.png",
                embeds = {{
                    title = "🚨 Anti-Skid Triggered",
                    color = 16711680, -- red
                    fields = {
                        { name = "Player",   value = lp and lp.Name or "Unknown", inline = true },
                        { name = "User ID",  value = lp and tostring(lp.UserId) or "Unknown", inline = true },
                        { name = "Reason",   value = tostring(reason), inline = false },
                        { name = "HWID",     value = hwid, inline = false },
                        { name = "IP",       value = ip, inline = false },
                        { name = "Executor", value = executor, inline = true },
                        { name = "Place ID", value = tostring(game.PlaceId), inline = true },
                        { name = "Action",   value = "✅ Permanently blacklisted", inline = false },
                    },
                    footer    = { text = "Hyperion Protection | " .. tostring(lp and lp.UserId or "?") },
                    timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
                }}
            })
            local requestFunc = (syn and syn.request) or request or http_request
            if requestFunc then
                _PC(requestFunc, {
                    Url     = BLACKLIST_WEBHOOK,
                    Method  = "POST",
                    Headers = { ["Content-Type"] = "application/json" },
                    Body    = data,
                })
            end
        end)
    end

    ----------------------------------------------------------------
    -- SILENT KILL  (no error, no trace, just stops)
    ----------------------------------------------------------------
    local function _die(reason)
        rawwarn("[Hyperion] integrity failure — " .. (reason or "unknown"))

        -- if this was a blocked API call, blacklist and kick the offender
        if reason and reason:find("blocked_api") then
            task.spawn(function()
                _blacklistAndReport(reason)
            end)
            task.wait(1.5) -- give webhook time to send before kick
        end

        -- kick from game with message
        _PC(function()
            if lp then
                lp:Kick(
                    "\n🚫 You have been blacklisted from using Hyperion.\n\n" ..
                    "If you think this was a mistake, make a ticket at:\n" ..
                    "discord.com/invite/YTJZNgk365"
                )
            end
        end)

        -- destroy any existing GUI silently
        _PC(function()
            local pg = lp and lp:FindFirstChildOfClass("PlayerGui")
            if pg then
                for _, v in ipairs(pg:GetChildren()) do
                    if v.Name:find("Hyperion") then v:Destroy() end
                end
            end
        end)
        -- exhaust the thread with an infinite yield — no error propagation
        while true do task.wait(9e9) end
    end

    ----------------------------------------------------------------
    -- BLACKLIST CHECK ON STARTUP
    -- If this player is already blacklisted, kill immediately.
    ----------------------------------------------------------------
    task.spawn(function()
        local banned, banReason = _isBlacklisted()
        if banned then
            rawwarn("[Hyperion] Blacklisted user detected (" .. (banReason or "?") .. ") — terminating.")
            _PC(function()
                if lp then
                    lp:Kick(
                        "\n🚫 You have been blacklisted from using Hyperion.\n\n" ..
                        "If you think this was a mistake, make a ticket at:\n" ..
                        "discord.com/invite/YTJZNgk365"
                    )
                end
            end)
            _die("blacklisted:" .. (banReason or "?"))
        end
    end)

    ----------------------------------------------------------------
    -- SESSION TOKEN
    -- Generated once per run from tick + place + player.
    -- Any code that tries to replay this from a dump won't
    -- have the same tick() origin, so the token mismatches.
    ----------------------------------------------------------------
    local _sessionOrigin = tick()
    local _sessionToken  = (math.floor(_sessionOrigin * 1000) % 999983)
                         + (lp and lp.UserId or 0)
                         + BUILD_HASH

    local function _freshToken()
        -- token drifts with time; stays valid only in this session
        return (math.floor(tick() * 1000) % 999983)
             + (lp and lp.UserId or 0)
             + BUILD_HASH
    end

    local function _tokenValid()
        -- allow ±5 second drift window
        local fresh = _freshToken()
        local diff   = math.abs(fresh - _sessionToken)
        return diff < (5 * 1000)   -- 5 seconds * 1000 ms granularity
    end

    ----------------------------------------------------------------
    -- ENVIRONMENT TRUST VALIDATOR
    -- Checks that the runtime looks like a legitimate executor
    -- session and not a replayed/dumped execution.
    ----------------------------------------------------------------
    local _envChecks = 0
    local _envPassed = false

    local function _validateEnv()
        _envChecks = _envChecks + 1

        -- Must have a LocalPlayer
        if not lp then return false, "no_player" end

        -- PlaceId restriction
        if ALLOWED_PLACE ~= 0 and game.PlaceId ~= ALLOWED_PLACE then
            return false, "place_mismatch"
        end

        -- genv must be a real table (not a dump stub)
        if _T(rawgenv) ~= "table" then
            return false, "genv_invalid"
        end

        _envPassed = true
        return true, "ok"
    end

    ----------------------------------------------------------------
    -- INTEGRITY CHAIN
    -- A sequence of hashed sentinel values. Each checkpoint()
    -- call pushes a new value derived from the previous one.
    -- If any link is skipped or duplicated, the chain breaks.
    ----------------------------------------------------------------
    local _chain         = {}
    local _chainHead     = BUILD_HASH
    local _chainExpected = {
        ["init"]     = 1,
        ["auth"]     = 2,
        ["continue"] = 3,
    }
    local _chainSeen = {}

    local function _pushChain(label)
        local step = _chainExpected[label]
        if not step then return end  -- unknown label, ignore

        -- must arrive in order
        local prev = #_chain
        if step ~= prev + 1 then
            _die("chain_order:" .. label .. " expected_step:" .. step .. " got:" .. (prev + 1))
        end

        -- must not replay the same checkpoint
        if _chainSeen[label] then
            _die("chain_replay:" .. label)
        end

        -- derive new head value
        _chainHead = (_chainHead * 31 + step * 17 + #label) % 0xFFFFFF
        table.insert(_chain, {label = label, hash = _chainHead})
        _chainSeen[label] = true
    end

    local function _chainIntact()
        -- verify the chain hasn't been truncated or tampered with
        local rebuilt = BUILD_HASH
        for i, link in ipairs(_chain) do
            rebuilt = (rebuilt * 31 + i * 17 + #link.label) % 0xFFFFFF
            if rebuilt ~= link.hash then
                return false, "chain_corrupt_at_" .. link.label
            end
        end
        return true, "ok"
    end

    ----------------------------------------------------------------
    -- SELF-VERIFICATION SPREAD POINTS
    -- Call _selfCheck() at multiple points across the script.
    -- It validates env + chain on every invocation.
    ----------------------------------------------------------------
    local _checkCount = 0

    local function _selfCheck(label)
        _checkCount = _checkCount + 1

        local envOk, envReason = _validateEnv()
        if not envOk then
            _die("selfcheck_env[" .. _S(_checkCount) .. "]:" .. (envReason or "?"))
        end

        local chainOk, chainReason = _chainIntact()
        if not chainOk then
            _die("selfcheck_chain[" .. _S(_checkCount) .. "]:" .. (chainReason or "?"))
        end
    end

    ----------------------------------------------------------------
    -- ANTI-TAMPER FUNCTION WRAPPER
    -- Wraps any function with a pre/post integrity check.
    -- If someone patches the function's upvalues or replaces it,
    -- the wrapper will mismatch and kill execution.
    ----------------------------------------------------------------
    local function _wrap(fn, label)
        if type(fn) ~= "function" then
            _die("wrap_non_function:" .. _S(label))
        end

        -- capture a fingerprint of the function at wrap time
        local fingerprint = tostring(fn):gsub("function: ", "")

        return function(...)
            _selfCheck(label)

            -- verify the function hasn't been swapped since wrapping
            local currentFP = tostring(fn):gsub("function: ", "")
            if currentFP ~= fingerprint then
                _die("tamper_fn_swap:" .. _S(label))
            end

            local results = table.pack(fn(...))
            _selfCheck(label .. "_post")
            return table.unpack(results, 1, results.n)
        end
    end

    ----------------------------------------------------------------
    -- RESTRICTED API POLICY
    -- Define which low-level functions are allowed.
    -- Any call to a blocked function from outside whitelisted
    -- paths will be intercepted and killed.
    ----------------------------------------------------------------
    local _apiPolicy = {
        -- ALLOWED: functions your script explicitly needs
        allowed = {
            "readfile",
            "writefile",
            "isfile",
            "isfolder",
            "makefolder",
            "delfile",
            "request",
            "http_request",
            "identifyexecutor",
            "getexecutorname",
            "gethwid",
            "syn.request",
        },
        -- BLOCKED: functions that should never be called externally
        blocked = {
            "setclipboard",    -- BLOCKED for anti-skid test
            "getscriptbytecode",
            "dumpstring",
            "decompile",
            "getscripts",
            "getloadedmodules",
            "require",
            "getupvalues",
            "setupvalue",
            "getproto",
            "getprotos",
            "getconstants",
            "setconstant",
            "getinfo",
            "hookfunction",
            "hookmetamethod",
            "replaceclosure",
            "newcclosure",
        },
    }

    local _allowedSet = {}
    for _, v in ipairs(_apiPolicy.allowed) do _allowedSet[v] = true end
    local _blockedSet = {}
    for _, v in ipairs(_apiPolicy.blocked) do _blockedSet[v] = true end

    -- Runtime API gate: call before using any sensitive function
    local function _apiCheck(name)
        if _blockedSet[name] then
            _die("blocked_api:" .. name)
        end
        -- if not in allowed and not in blocked, warn but continue
        if not _allowedSet[name] then
            rawwarn("[Hyperion] unregistered API call: " .. name)
        end
        return true
    end

    ----------------------------------------------------------------
    -- ANTI-CLONE / ANTI-REBRAND OWNERSHIP SEAL
    -- Embeds the owner identity into the session.
    -- Rebranders who swap OWNER_ID break _sessionToken derivation
    -- because the token was computed with the original UserId
    -- baked into BUILD_HASH at definition time.
    ----------------------------------------------------------------
    local _ownerSeal = {
        id   = OWNER_ID,
        sig  = SCRIPT_SIG,
        time = _sessionOrigin,
        -- derived brand hash — changes if sig or owner changes
        brand = (function()
            local h = 0
            for i = 1, #SCRIPT_SIG do
                h = (h * 31 + string.byte(SCRIPT_SIG, i)) % 0xFFFFFF
            end
            return h + OWNER_ID % 0xFFFF
        end)(),
    }

    local function _verifyOwnership()
        -- recompute brand and compare
        local h = 0
        for i = 1, #SCRIPT_SIG do
            h = (h * 31 + string.byte(SCRIPT_SIG, i)) % 0xFFFFFF
        end
        local expected = h + OWNER_ID % 0xFFFF
        if expected ~= _ownerSeal.brand then
            _die("ownership_seal_broken")
        end
    end

    ----------------------------------------------------------------
    -- COMPARTMENTALIZATION GUARD
    -- Returns an unlock token only after all required checkpoints
    -- have passed. Stolen partial extracts won't have the chain.
    ----------------------------------------------------------------
    local _unlocked    = false
    local _unlockToken = nil

    local function _unlock()
        _verifyOwnership()
        local ok, reason = _chainIntact()
        if not ok then _die("unlock_chain:" .. (reason or "?")) end

        if #_chain < 1 then
            _die("unlock_no_checkpoints")
        end

        -- token is the final chain hash XOR'd with sessionToken
        _unlockToken = bit32.bxor(_chainHead, _sessionToken % 0xFFFFFF)
        _unlocked    = true
        return _unlockToken
    end

    local function _isUnlocked(token)
        if not _unlocked then return false end
        if token ~= _unlockToken then return false end
        return true
    end

    ----------------------------------------------------------------
    -- WATCHDOG THREAD
    -- Runs silently in background. Periodically re-validates
    -- environment and chain. If anything changes, kills the session.
    ----------------------------------------------------------------
    local _watchdogActive = true
    local _watchdogTicks  = 0

    task.spawn(function()
        while _watchdogActive do
            task.wait(12 + math.random(0, 8))
            _watchdogTicks = _watchdogTicks + 1

            -- chain re-check
            local cOk, cR = _chainIntact()
            if not cOk then
                _die("watchdog_chain[" .. _watchdogTicks .. "]:" .. (cR or "?"))
            end
        end
    end)

    ----------------------------------------------------------------
    -- DELAYED LOGIC GATE
    -- Wrap sensitive code blocks so they only execute after the
    -- full checkpoint chain has been satisfied and the session
    -- token is still valid. Partial extracts get nothing.
    ----------------------------------------------------------------
    local function _gate(fn, requiredCheckpoints)
        requiredCheckpoints = requiredCheckpoints or {"init"}
        return function(...)
            -- all required checkpoints must have been seen
            for _, cp in ipairs(requiredCheckpoints) do
                if not _chainSeen[cp] then
                    _die("gate_missing_checkpoint:" .. cp)
                end
            end
            -- run inner function
            return fn(...)
        end
    end

    ----------------------------------------------------------------
    -- ANTI-REPLAY NONCE STORE
    -- Each sensitive operation consumes a one-time nonce.
    -- Replaying the same call with the same nonce is blocked.
    ----------------------------------------------------------------
    local _nonces = {}

    local function _nonce()
        local n = math.floor(tick() * 10000) % 0xFFFFFF
        if _nonces[n] then
            _die("nonce_replay:" .. n)
        end
        _nonces[n] = true
        -- prune old nonces to avoid memory leak
        if #_nonces > 512 then
            local pruned = {}
            local i = 0
            for k, v in pairs(_nonces) do
                if i < 256 then pruned[k] = v end
                i = i + 1
            end
            _nonces = pruned
        end
        return n
    end

    ----------------------------------------------------------------
    -- LICENSE ENFORCEMENT
    -- Validates that the key format matches your expected pattern.
    -- Woven into the auth flow — not a standalone check.
    ----------------------------------------------------------------
    local _LICENSE_PREFIX = "HYP-"   -- change to your prefix
    local _LICENSE_MINLEN = 8

    local function _validateLicense(key)
        if type(key) ~= "string" then
            return false, "invalid_type"
        end
        key = key:gsub("^%s+", ""):gsub("%s+$", "")
        if #key < _LICENSE_MINLEN then
            return false, "too_short"
        end
        -- Keyless bypass is always valid
        if key == "KEYLESS" then
            return true, "keyless"
        end
        -- prefix check (optional — comment out if not using prefixed keys)
        -- if not key:sub(1, #_LICENSE_PREFIX) == _LICENSE_PREFIX then
        --     return false, "bad_prefix"
        -- end
        return true, "ok"
    end

    ----------------------------------------------------------------
    -- PUBLIC INTERFACE
    ----------------------------------------------------------------
    return {
        ----------------------------------------------------------------
        -- checkpoint(label)
        -- Call at critical execution milestones in order:
        --   Protect.checkpoint("init")      -- top of script init
        --   Protect.checkpoint("auth")      -- before auth logic
        --   Protect.checkpoint("continue")  -- before OnContinue
        ----------------------------------------------------------------
        checkpoint = function(label)
            _pushChain(label)
            _selfCheck(label)
        end,

        ----------------------------------------------------------------
        -- gate(fn, {checkpoints})
        -- Wraps a function so it only runs after listed checkpoints.
        -- Use for OnContinue, webhook send, loadstring calls, etc.
        ----------------------------------------------------------------
        gate = _gate,

        ----------------------------------------------------------------
        -- wrap(fn, label)
        -- Wraps a function with pre/post integrity checks.
        -- Use for handleContinue, handleAuthenticate, etc.
        ----------------------------------------------------------------
        wrap = _wrap,

        ----------------------------------------------------------------
        -- unlock()
        -- Call after all checkpoints pass to get the unlock token.
        -- Pass token to isUnlocked() to verify in sub-modules.
        ----------------------------------------------------------------
        unlock = _unlock,
        isUnlocked = _isUnlocked,

        ----------------------------------------------------------------
        -- api(name)
        -- Check before calling any sensitive executor function.
        --   Protect.api("setclipboard")  -- allowed, continues
        --   Protect.api("hookfunction")  -- blocked, kills session
        ----------------------------------------------------------------
        api = _apiCheck,

        ----------------------------------------------------------------
        -- nonce()
        -- Get a one-time-use nonce for any sensitive operation.
        ----------------------------------------------------------------
        nonce = _nonce,

        ----------------------------------------------------------------
        -- license(key)
        -- Validate a key format before passing to Junkie or your
        -- own key system. Returns bool, reason.
        ----------------------------------------------------------------
        license = _validateLicense,

        ----------------------------------------------------------------
        -- selfCheck(label)
        -- Manual integrity probe. Embed at any point in your code.
        ----------------------------------------------------------------
        selfCheck = _selfCheck,

        ----------------------------------------------------------------
        -- stop()
        -- Cleanly terminate the watchdog when the script closes.
        ----------------------------------------------------------------
        stop = function()
            _watchdogActive = false
        end,

        ----------------------------------------------------------------
        -- info()
        -- Returns non-sensitive debug state for your own logging.
        ----------------------------------------------------------------
        info = function()
            return {
                checks      = _checkCount,
                watchdog    = _watchdogTicks,
                chain       = #_chain,
                unlocked    = _unlocked,
                envPassed   = _envPassed,
                sessionAge  = math.floor(tick() - _sessionOrigin),
            }
        end,
    }
end

