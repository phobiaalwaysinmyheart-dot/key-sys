local _fs  = typeof(isfile)    == "function"
          and typeof(writefile) == "function"
          and typeof(readfile)  == "function"
local _fsd = _fs
          and typeof(isfolder)   == "function"
          and typeof(makefolder) == "function"

local function _path() return CONFIG.StorageFolder.."/"..CONFIG.StorageFile end

local function _enc(t)
    local p = {}
    for k, v in pairs(t) do
        local s = type(v) == "string"
            and ('"' .. tostring(v):gsub('"', '\\"') .. '"')
            or tostring(v)
        p[#p+1] = '"'..k..'":'..s
    end
    return "{"..table.concat(p,",").."}"
end

local function _dec(s)
    local r = {}
    if type(s) ~= "string" then return r end
    for k, v in s:gmatch('"([%w_]+)"%s*:%s*"([^"]*)"')  do r[k] = v end
    for k, v in s:gmatch('"([%w_]+)"%s*:%s*([%d%.%-]+)') do r[k] = tonumber(v) or v end
    return r
end

local SAFE = {lastKey=1, discordID=1, username=1, displayName=1, accessType=1, lastLogin=1}

local Store = {}
function Store.load()
    if not _fs then return {} end
    local ok, raw = pcall(function()
        return isfile(_path()) and readfile(_path()) or nil
    end)
    if not ok or not raw then return {} end
    local d, s = _dec(raw), {}
    for k, v in pairs(d) do
        if SAFE[k] and (type(v) == "string" or type(v) == "number") then
            s[k] = tostring(v)
        end
    end
    return s
end
function Store.save(t)
    if not _fs then return false end
    return pcall(function()
        if _fsd and not isfolder(CONFIG.StorageFolder) then
            makefolder(CONFIG.StorageFolder)
        end
        writefile(_path(), _enc(t))
    end)
end
function Store.clear()
    if not _fs then return end
    pcall(function()
        if isfile(_path()) then writefile(_path(), "{}") end
    end)
end

