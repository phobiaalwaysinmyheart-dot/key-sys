-- § 7 · ANIMATED PARTICLES
-- Fully drawn (no external image assets) — always renders
-- ════════════════════════════════════════════════════════════════

local function StartParticles(parent, aliveCheck)
    local rng = Random.new()
    local function spawnOrb()
        if not aliveCheck() then return end
        local sz  = rng:NextInteger(3, 16)
        local orb = Frm(parent,
            Color3.fromHSV(rng:NextNumber(0.71, 0.84), rng:NextNumber(0.55, 1), 1),
            UDim2.new(0, sz, 0, sz),
            UDim2.new(rng:NextNumber(0.02, 0.98), 0, 1.04, 0),
            Vector2.new(0.5, 0.5),
            math.ceil(sz / 2),
            rng:NextNumber(0.28, 0.62)
        )
        orb.ZIndex = 2
        local dur  = rng:NextNumber(9, 20)
        local dstX = rng:NextNumber(-0.05, 0.05)
        tw(orb, TweenInfo.new(dur, Enum.EasingStyle.Linear), {
            Position = UDim2.new(orb.Position.X.Scale + dstX, 0, -0.06, 0),
            BackgroundTransparency = 1,
        })
        Debris:AddItem(orb, dur + 0.2)
    end

    for i = 1, 18 do
        task.delay(rng:NextNumber(0, 2.5), spawnOrb)
    end
    task.spawn(function()
        while aliveCheck() do
            task.wait(rng:NextNumber(0.45, 1.1))
            spawnOrb()
        end
    end)
end

