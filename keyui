local function trim(s)
    if typeof(s) ~= "string" then
        return ""
    end
    return s:gsub("^%s+", ""):gsub("%s+$", "")
end

local function clampString(s, maxLen)
    s = trim(s)
    if #s > maxLen then
        return s:sub(1, maxLen)
    end
    return s
end

