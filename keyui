local function applyResponsiveScale(window)
    local uiScale = Instance.new("UIScale")
    uiScale.Parent = window

    local function updateScale()
        local viewport = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)
        local scaleValue = math.clamp(math.min(viewport.X / 1920, viewport.Y / 1080), 0.72, 1)
        uiScale.Scale = scaleValue
    end

    updateScale()
    if workspace.CurrentCamera then
        connect(workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"), updateScale)
    end
end

local function setupDragging(dragArea, window)
    connect(dragArea.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            Controller.State.Dragging = true
            Controller.State.DragStart = input.Position
            Controller.State.WindowStart = window.Position

            local releaseConn
            releaseConn = input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    Controller.State.Dragging = false
                    releaseConn:Disconnect()
                end
            end)
        end
    end)

    connect(RunService.RenderStepped, function()
        if Controller.State.Dragging and Controller.State.DragStart and Controller.State.WindowStart then
            local mousePos = game:GetService("UserInputService"):GetMouseLocation()
            local delta = mousePos - Controller.State.DragStart
            window.Position = UDim2.new(
                Controller.State.WindowStart.X.Scale,
                Controller.State.WindowStart.X.Offset + delta.X,
                Controller.State.WindowStart.Y.Scale,
                Controller.State.WindowStart.Y.Offset + delta.Y
            )
        end
    end)
end

